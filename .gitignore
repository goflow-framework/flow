# === Flow .gitignore ===

# Binaries and build artifacts
*.exe
*.dll
*.so
*.dylib
*.o
*.out
*.test
/ci-export-*/*

# Common build/output directories
/bin/
/build/
/dist/
/obj/
/target/

# Local temp/cache
/tmp/
/.cache/

# Vendor (if you vendor dependencies locally)
/vendor/

# Profiling, benchmark and coverage outputs
*.prof
*.pprof
*.cov
coverage.out
bench-output/
*.svg
flame*.svg

# Logs and runtime artifacts
*.log
nohup.out
pprof_client.log
pprof_server.log
artifacts/*

# Databases
*.db
*.sqlite
*.sqlite3

# Environment files (secrets)
.env
.env.*

# Node
node_modules/

# Editors/IDEs
.idea/
.vscode/
*.swp
*~
*.iml
.project

# OS junk
.DS_Store
Thumbs.db

# Misc
*.bak
*.tmp

# Ignore any prof files anywhere
**/*.prof
**/*.tar.gz
**/*.zip

# Ignore repo-level built executables
/flow
/flow-cli
/flow-worker
/pprof_client
/pprof_server

# Ignore tool-built binaries
/tools/**/bin/
/tools/**/bin/*

# End of .gitignore
