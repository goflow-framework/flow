# Enforce LF line endings for shell scripts, Dockerfiles, and GitHub workflows
# This prevents CRLF shebang issues inside Linux-based CI/container images.

# Shell scripts
*.sh text eol=lf
.github/scripts/*.sh text eol=lf

# Dockerfiles
Dockerfile text eol=lf
.github/containers/**/Dockerfile text eol=lf

# GitHub Actions workflows and YAML files
*.yml text eol=lf
.github/workflows/*.yml text eol=lf

# Other text files
*.md text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.Dockerfile text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.ps1 text eol=crlf